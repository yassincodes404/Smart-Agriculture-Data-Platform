{
  "expo": {
    "name": "AgriData Egypt",
    "slug": "agridata-egypt",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#052e16"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "AgriData needs your location to center the map on your farm."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.agridata.egypt",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "AgriData needs your location to center the map on your farm."
      }
    },
    "android": {
      "package": "com.agridata.egypt",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"]
    },
    "extra": {
      "apiBaseUrl": "http://10.0.2.2:8000/api/v1"
    }
  }
}