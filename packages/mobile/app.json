{
  "expo": {
    "name": "AgriData Egypt",
    "slug": "agridata-egypt",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#052e16"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "AgriData needs your location to center the map on your farm."
        }
      ],
      "@react-native-google-signin/google-signin"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.company.smart_agri",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "AgriData needs your location to center the map on your farm."
      }
    },
    "android": {
      "package": "com.company.smart_agri",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "extra": {
      "apiBaseUrl": "https://smartagri.azurewebsites.net/api/v1",
      "eas": {
        "projectId": "27c201d9-c446-4ee0-8c3c-1b6fbd84a5e9"
      }
    }
  }
}
