# ============================================================
#  Smart Agriculture Data Platform — .gitignore
# ============================================================

# ── Environment & Secrets ────────────────────────────────────
.env
secrets/
*.pem
*.key

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/

# ── Data (keep in MinIO, not Git) ────────────────────────────
data/
*.tif
*.tiff
*.nc
*.hdf
*.h5
*.csv
*.parquet

# ── Jupyter ──────────────────────────────────────────────────
.ipynb_checkpoints/

# ── IDE ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
