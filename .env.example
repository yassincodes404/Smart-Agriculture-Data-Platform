# ============================================================
#  Smart Agriculture Data Platform — Environment Variables
#  Copy:  cp .env.example .env   then fill in values
# ============================================================

# ── Jupyter ──────────────────────────────────────────────────
JUPYTER_PORT=8888

# ── Google Earth Engine ──────────────────────────────────────
GEE_SERVICE_ACCOUNT_KEY=
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/gee-sa-key.json

# ── Copernicus CDS (ERA5) ───────────────────────────────────
CDSAPI_URL=https://cds.climate.copernicus.eu/api/v2
CDSAPI_KEY=

# ── NASA AppEEARS ───────────────────────────────────────────
APPEEARS_USER=
APPEEARS_PASSWORD=
